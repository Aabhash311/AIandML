      "source": [
        "# Visualise 10 sample images from the training set\n",
        "plt.figure(figsize=(12, 4))\n",
        "for i in range(10):\n",
        "    plt.subplot(2, 5, i + 1)\n",
        "    plt.imshow(x_train[i].reshape(IMG_HEIGHT, IMG_WIDTH), cmap=\"gray\")\n",
